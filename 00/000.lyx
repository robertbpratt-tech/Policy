\begin_layout Subsection*
Authority and Scope
\end_layout

\begin_layout Standard
This manual,
 alongside the procedural library maintained in the System of Engagement (Redmine),
 serves as the primary reference for governance,
 operational decision-making,
 audit defense,
 and interdepartmental service level agreements.
\end_layout

\begin_layout Standard
Compliance with these policies is 
\series bold
mandatory
\series default
 for:
\end_layout

\begin_layout Enumerate
All Elko County Information Operations personnel.
\end_layout

\begin_layout Enumerate
All County employees,
 contractors,
 and vendors who access,
 administer,
 or support County information systems,
 infrastructure,
 or data governed by the Information Operations Department.
\end_layout

