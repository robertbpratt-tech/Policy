 Purpose
\end_layout

\begin_layout Standard

\lang english
This policy defines the internal culture,
 operational mindset,
 and behavioral expectations of the 
\series bold
Elko County Information Operations
\series default
 Department (ECIO).
\end_layout

\begin_layout Subsection*

\lang english
2.
 Scope
\end_layout

\begin_layout Standard

\lang english
This policy applies to all Information Operations personnel,
 including full-time employees,
 part-time staff,
 contractors,
 vendors,
 and volunteers.
\end_layout

