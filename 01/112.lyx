\begin_layout Subsection*

\lang english
3.
 Roles and Responsibilities
\end_layout

\begin_layout Itemize

\series bold
\lang english
IT Director
\series default
:
\end_layout

\begin_deeper
\begin_layout Itemize

\lang english
Shall maintain IT asset property and equipment records and inventory controls pursuant to NRS 354.625.
\end_layout

\begin_layout Itemize

\lang english
Shall serve as the final approving authority for lifecycle standards,
 replacement determinations,
 and decommissioning actions.
\end_layout

\begin_layout Itemize

\lang english
Shall approve all retire,
 transfer,
 and disposition decisions for County IT assets.
\end_layout

\begin_layout Itemize

\lang english
Shall ensure that asset records in the System of Engagement are maintained current and complete.
\end_layout

\begin_layout Itemize

\lang english
Shall provide an annual asset reconciliation report to the Office of Fiscal Affairs.
\end_layout

\end_deeper
\begin_layout Itemize

\series bold
\lang english
Assistant IT Director
\series default
:
\end_layout

\begin_deeper
\begin_layout Itemize

\lang english
Shall maintain the At-Risk asset list as a continuously updated view in the System of Engagement.
\end_layout

\begin_layout Itemize

\lang english
Shall conduct the annual physical inventory audit and reconciliation cycle defined in Section 6.7.
\end_layout

\end_deeper
\begin_layout Itemize

\series bold
\lang english
All Information Operations Personnel
\series default
:
\end_layout

\begin_deeper
\begin_layout Itemize

\lang english
Shall execute asset receiving,
 tagging,
 asset record creation,
 and deployment tasks in accordance with this policy.
\end_layout

\begin_layout Itemize

\lang english
Shall process all asset transfers,
 relocations,
 and reassignments through the work order system.
\end_layout

\begin_layout Itemize

\lang english
Shall execute secure decommissioning and sanitization actions under Section 6.10.
\end_layout

\begin_layout Itemize

\lang english
Shall deny network connectivity and technical support to any asset that lacks a valid County IT asset tag or that is not recorded in the System of Engagement.
\end_layout

\end_deeper
\begin_layout Itemize

\series bold
\lang english
Department Heads
\series default
:
\end_layout

\begin_deeper
\begin_layout Itemize

\lang english
Shall ensure that department personnel do not remove,
 transfer,
 relocate,
 or dispose of any County IT asset without processing the action through the Information Operations Department.
\end_layout

\begin_layout Itemize

\lang english
Shall report loss,
 theft,
 damage,
 or suspected compromise of assigned IT assets to the Information Operations Department immediately upon discovery,
 and in no event later than one (1) hour following discovery.
\end_layout

\end_deeper
\begin_layout Itemize

\series bold
\lang english
All County Personnel
\series default
:
\end_layout

\begin_deeper
\begin_layout Itemize

\lang english
Shall protect assigned County IT assets from theft,
 damage,
 and unauthorized access.
\end_layout

\begin_layout Itemize

\lang english
Shall report loss,
 theft,
 or suspected compromise of any assigned IT asset to the Information Operations Department immediately upon discovery,
 and in no event later than one (1) hour following discovery.
\end_layout

\end_deeper
