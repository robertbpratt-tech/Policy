\begin_layout Subsection*

\lang english
1.
 Purpose
\end_layout

\begin_layout Standard

\lang english
This policy establishes the governance framework for the lifecycle management of Information Technology (IT) assets owned,
 leased,
 or operated by Elko County.
\end_layout

\begin_layout Subsection*

\lang english
2.
 Scope
\end_layout

\begin_layout Standard

\lang english
This policy applies to all IT assets acquired,
 leased,
 managed,
 deployed,
 connected,
 or supported by Elko County,
 regardless of funding source.
\end_layout

