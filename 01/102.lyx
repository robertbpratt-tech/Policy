1.
 Purpose
\end_layout

\begin_layout Standard

\lang english
This policy establishes the mandatory standard of professional conduct for all personnel within the Elko County Information Operations Department.
\end_layout

\begin_layout Subsection*

\lang english
2.
 Scope
\end_layout

\begin_layout Standard

\lang english
This policy applies to all Elko County Information Operations personnel,
 including full-time employees,
 part-time staff,
 contractors,
 vendors,
 interns,
 and volunteers who access County IT systems or data.
\end_layout

