\end_layout

\begin_layout Standard

\lang english
The County Manager shall determine when governance matters require Board of County Commissioners engagement.
 The following trigger criteria shall inform that determination.
\end_layout

\begin_layout Itemize

\series bold
\lang english
Mandatory Board Engagement
\series default
:
 The County Manager shall present the following matters to the Board of County Commissioners for approval or ratification.
\end_layout

\begin_deeper
\begin_layout Itemize

