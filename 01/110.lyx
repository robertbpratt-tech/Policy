1.
 Purpose
\end_layout

\begin_layout Standard

\lang english
This policy establishes mandatory internal controls over the financial stewardship and procurement of County technology resources.
\end_layout

\begin_layout Subsection*

\lang english
2.
 Scope
\end_layout

\begin_layout Standard

\lang english
This policy applies to all technology-related financial transactions conducted by any Elko County entity,
 department,
 or elected office,
 regardless of funding source or purchasing mechanism.
\end_layout

