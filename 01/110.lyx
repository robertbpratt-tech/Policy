\begin_layout Subsection*

\lang english
3.
 Roles and Responsibilities
\end_layout

\begin_layout Itemize

\series bold
\lang english
IT Director:
\end_layout

\begin_deeper
\begin_layout Itemize

\lang english
Shall serve as the Technical Authority for all County technology procurement.
\end_layout

\begin_layout Itemize

\lang english
Shall approve technical specifications,
 security requirements,
 and lifecycle and architectural impact for all technology procurement prior to the obligation of funds,
 the execution of purchasing actions,
 or the acceptance of contract terms.
\end_layout

\begin_layout Itemize

\lang english
Shall own County IT vendor technical standards,
 security requirements,
 and technical dispute escalation.
\end_layout

\begin_layout Itemize

\lang english
Shall designate technical approvers only through 
\series bold
Policy 
\begin_inset CommandInset ref
LatexCommand ref
reference "pol:1.08"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset


\series default
 (Delegation of Authority and Decision Rights).
\end_layout

\begin_layout Itemize

\lang english
Shall document each technical-approver designation.
\end_layout

\end_deeper
\begin_layout Itemize

\series bold
\lang english
Assistant IT Director:
\end_layout

\begin_deeper
\begin_layout Itemize

\lang english
Shall maintain procurement tracking artifacts required for audit and reconciliation,
 including the linkage of purchases to requisitions,
 receiving records,
 work orders,
 project codes,
 inventory entries,
 and Configuration Management Database (CMDB) entries maintained under 
\series bold
Policy 
\begin_inset CommandInset ref
LatexCommand ref
reference "pol:3.08"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset


\series default
 (Service Configuration Management (CMDB) Policy).
\end_layout

\begin_layout Itemize

\lang english
Shall provide oversight of procurement workflow execution.
\end_layout

\begin_layout Itemize

\lang english
Shall resolve workflow exceptions that exceed Administrative Assistant authority.
\end_layout

\end_deeper
\begin_layout Itemize

\series bold
\lang english
Administrative Assistant:
\end_layout

\begin_deeper
\begin_layout Itemize

\lang english
Shall execute day-to-day procurement workflow tasks —
 including requisition preparation,
 purchase order tracking,
 and receiving coordination —
 as directed by the Assistant IT Director.
\end_layout

\end_deeper
\begin_layout Itemize

\series bold
\lang english
Office of Fiscal Affairs:
\end_layout

\begin_deeper
\begin_layout Itemize

\lang english
Shall verify budget availability for all technology procurement prior to commitment of funds.
\end_layout

\begin_layout Itemize

\lang english
Shall execute purchasing and payment activities in accordance with applicable County procurement rules and NRS 332.
\end_layout

\begin_layout Itemize

\lang english
Shall not process technology invoices,
 reimbursements,
 or payment requests that lack documented Technical Approval from the IT Director or a formally delegated technical approver.
\end_layout

\end_deeper
\begin_layout Itemize

\series bold
\lang english
Department Heads:
\end_layout

\begin_deeper
\begin_layout Itemize

\lang english
Shall define business requirements for departmental technology needs.
\end_layout

\begin_layout Itemize

\lang english
Shall coordinate with the Information Operations Department to validate technology requirements prior to initiating procurement.
\end_layout

\begin_layout Itemize

\lang english
Shall not negotiate technology vendor agreements without Information Operations Department review and documented Technical Approval.
\end_layout

\begin_layout Itemize

\lang english
Shall not authorize technology procurement without Information Operations Department review and documented Technical Approval.
\end_layout

\begin_layout Itemize

\lang english
Shall not accept or execute technology contract terms —
 including click-through terms,
 End User License Agreements (EULAs),
 Master Service Agreements (MSAs),
 Statements of Work (SOWs),
 renewals,
 and auto-renewals —
 without Information Operations Department review and documented Technical Approval.
\end_layout

\end_deeper
