\begin_layout Subsubsection*
6.7 Reclassification
\end_layout

\begin_layout Standard

\lang english
Data classification is not static.
 Department Heads shall review classifications annually,
 at minimum,
 and shall update classification when sensitivity,
 disclosure status,
 legal posture,
 or operational context changes.
\end_layout

\begin_layout Itemize

\series bold
\lang english
CJI Reclassification Constraint
\series default
:
\end_layout

\begin_deeper
\begin_layout Itemize

\lang english
The LASO shall not authorize downward reclassification of Restricted CJI without written authorization from any additional CJIS authority required by governing agreements.
\end_layout

\begin_layout Itemize

\lang english
The LASO shall retain written authorization with the classification decision record.
\end_layout

\end_deeper

