\begin_layout Subsection*

\lang english
1.
 Purpose
\end_layout

\begin_layout Standard

\lang english
This policy governs internal and external communications conducted by the Elko County Information Operations Department,
 including formal and informal communication boundaries,
 stakeholder engagement,
 and incident-adjacent reporting obligations.
\end_layout

\begin_layout Subsection*

\lang english
2.
 Scope
\end_layout

\begin_layout Standard

\lang english
This policy applies to all Information Operations personnel,
 including full-time employees,
 part-time staff,
 contractors,
 vendors,
 and volunteers,
 and governs communications with County leadership,
 elected and appointed officials,
 department heads,
 third-party vendors and contractors,
 regulatory bodies,
 and the public.
\end_layout

