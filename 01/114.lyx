\series default
 §6.1,
 shall be exercised with this awareness in mind.
\end_layout

\begin_layout Standard

\lang english
Records generated under this policy shall be classified,
 retained,
 and disposed of in accordance with 
\series bold
Policy 
\begin_inset CommandInset ref
