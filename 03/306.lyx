\begin_layout Subsection*

\lang english
1.
 Purpose
\end_layout

\begin_layout Standard

\lang english
This policy governs the detection,
 intake,
 triage,
 resolution,
 and closure of operational incidents within the Elko County Information Operations Department (ECIO),
 and establishes the mandatory jurisdictional transfer procedure when an Indicator of Compromise (IoC) is discovered during an operational response.
\end_layout

\begin_layout Subsection*

\lang english
2.
