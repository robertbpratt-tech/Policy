nolink "false"

\end_inset


\series default
;
 this policy governs the KB mechanics of the entry lifecycle.
\end_layout

\begin_layout Itemize

\lang english
Upon Known Error declaration,
 the Assistant IT Director shall ensure publication within the timeframe established in 
\series bold
Policy 
