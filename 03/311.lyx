caps "false"
noprefix "false"
nolink "false"

\end_inset


\series default
 SLA targets,
 distinguishing planned and unplanned downtime.
\end_layout

\begin_layout Itemize

\lang english
Threshold breaches recorded during the quarter and any threshold risk trends identified through monitoring under 
\series bold
Policy 
\begin_inset CommandInset ref
LatexCommand ref
reference "pol:3.12"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset


\series default
.
\end_layout

\begin_layout Itemize

\lang english
Identified trends or emerging gaps.
\end_layout

\begin_layout Itemize

\lang english
Status of any active remediation plans.
\end_layout

\begin_layout Standard

\lang english
The Assistant IT Director shall schedule the quarterly briefing cycle to support County budget planning milestones.
\end_layout

