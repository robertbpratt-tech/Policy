\begin_layout Subsection*

\lang english
1.
 Purpose
\end_layout

\begin_layout Standard

\lang english
This policy governs the real-time monitoring,
 event classification,
 and automated work order generation for all IT services,
 infrastructure,
 endpoints,
 and applications administered by the Elko County Information Operations Department (ECIO).
\end_layout

