caps "false"
noprefix "false"
nolink "false"

\end_inset


\series default
 (Recovery Operations and Restoration Prioritization) begins.
\end_layout

\begin_layout Itemize

\lang english
Shall confirm that forensic preservation requirements have been satisfied before authorizing any destructive or irreversible eradication action.
\end_layout

\begin_layout Itemize

\lang english
Shall complete Configuration Control Authority (CCA) review for all eradication-phase Emergency Changes within the twenty-four (24) hour concurrent documentation window established by 
