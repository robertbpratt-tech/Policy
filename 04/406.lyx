plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset


\series default
 (Security Control Assessment and Authorization) through the notification mechanics defined in Section 6.4.
\end_layout

\begin_layout Itemize

\lang english
Shall ensure the incident response contact directory is validated annually in accordance with Section 6.12.
\end_layout

\end_deeper
