caps "false"
noprefix "false"
nolink "false"

\end_inset


\series default
 (Delegation of Authority and Decision Rights).
\end_layout

\begin_layout Itemize

\lang english
Shall review Safety and Security work orders in the System of Engagement queue and release them to Reviewed status upon declaration,
 or document the basis for decline in the work order notes.
\end_layout

\begin_layout Itemize

\lang english
Shall execute CJIS IR-6 Part (b) external notification obligations in the role of LASO,
 within the notification windows established in Section 6.6 of this policy.
\end_layout

\begin_layout Itemize

\lang english
Shall approve any structural change to Layer 1 IoC categories or definitions.
\end_layout

\begin_layout Itemize

\lang english
Shall identify in writing the Tier L3+ technical leads authorized to declare incidents and serve as Incident Commander,
 per 
\series bold
Policy 
