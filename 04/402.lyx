\end_layout

\begin_layout Itemize

\lang english
Shall own and maintain the Layer 2 IoC indicator artifact in the System of Engagement under standing maintenance authority,
 with IT Director notification upon each update.
\end_layout

\begin_layout Itemize

\lang english
Shall conduct the thirty (30) day false positive indicator review for each flagged indicator.
\end_layout

\begin_layout Itemize

\lang english
Shall conduct the quarterly IoC list review.
\end_layout

\begin_layout Itemize

\lang english
