\begin_layout Subsection*

\lang english
1.
 Purpose
\end_layout

\begin_layout Standard

\lang english
This policy establishes the identification,
 intake,
 triage,
 classification,
 notification,
 and documentation obligations for all cybersecurity incidents within the Elko County Information Operations Department (ECIO).
\end_layout

\begin_layout Subsection*

\lang english
2.
