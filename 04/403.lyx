plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset


\series default
 Section 6.3.
\end_layout

\begin_layout Itemize

\lang english
Any containment action that destroys,
 overwrites,
 or causes the disposition of audit logs.
\end_layout

\begin_layout Itemize

\lang english
Failure to document a containment-complete determination in the work order Notes before initiating eradication activity.
\end_layout

\end_deeper
\begin_layout Standard

\lang english
Non-compliance may result in corrective action in accordance with 
\series bold
Policy 
