    pdfborder={0 0 0} % Removes ugly boxes around links
}

% 3. Header/Footer Styling (STRICT RIGHT)
\usepackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{} % Clear all default headers/footers

% --- Configuration for Normal Pages ---
\lhead{\small \textbf{\nouppercase{\leftmark}}} % Chapter Title on Left
\rfoot{\small Page \thepage}                    % Page Number on Right
\renewcommand{\headrulewidth}{1pt}

% --- Configuration for Chapter Start Pages (The "Plain" Style) ---
% LaTeX tries to center these by default. We must override it.
\fancypagestyle{plain}{
  \fancyhf{}                   % Clear the center number
  \rfoot{\small Page \thepage} % Force it to the Right
  \renewcommand{\headrulewidth}{0pt} % Optional: No header line on Chapter 1 page
}

% 4. Fix Chapter Headings (Remove "Chapter 1" giant text)
\usepackage{titlesec}
\titleformat{\chapter}[hang]
  {\Huge\bfseries} % Format
  {\thechapter.}   % Label (e.g., "1.")
  {1em}            % Spacing
  {}               
\titlespacing*{\chapter}{0pt}{-30pt}{20pt}

% 5. Policy Metadata Environment (Visual Box)

% 5. Policy Metadata Environment
% Usage: Type "Date", Insert Horizontal Fill, Type "Version"
\newenvironment{policymetadata}{
    \vspace{-15pt}
    \noindent\rule{\textwidth}{0.5pt} \\
    \footnotesize \sffamily
    \noindent
}{
