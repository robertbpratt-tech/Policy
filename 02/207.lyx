\begin_layout Subsection*

\lang english
1.
 Purpose
\end_layout

\begin_layout Standard

\lang english
This policy establishes mandatory technical and procedural controls for protecting Elko County information systems and data during transmission and storage.
\end_layout

\begin_layout Subsection*

\lang english
2.
 Scope
\end_layout

\begin_layout Standard

\lang english
This policy applies to all Elko County Information Operations (ECIO) personnel,
 County employees,
 elected officials,
 contractors,
 vendors,
 and any other individuals or services accessing County information systems.
\end_layout

