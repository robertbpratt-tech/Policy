\begin_layout Subsection*

\lang english
1.
 Purpose
\end_layout

\begin_layout Standard

\lang english
This policy establishes the requirements for identifying,
 scoring,
 remediating,
 and verifying technical vulnerabilities in Elko County information systems.
\end_layout

\begin_layout Subsection*

\lang english
2.
 Scope
\end_layout

\begin_layout Standard

\lang english
This policy applies to all Elko County information systems,
 networks,
 endpoints,
 applications,
 and supporting infrastructure owned,
 leased,
 operated,
 or managed by Elko County,
 including all systems that process,
 store,
 or transmit Criminal Justice Information (CJI).
\end_layout

