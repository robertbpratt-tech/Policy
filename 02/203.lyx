\begin_layout Subsection*

\lang english
3.
 Roles and Responsibilities
\end_layout

\begin_layout Itemize

\series bold
\lang english
IT Director
\series default
:
\end_layout

\begin_deeper
\begin_layout Itemize

\lang english
Shall approve the security awareness and role-based training curriculum design.
\end_layout

\begin_layout Itemize

\lang english
Shall review the training curriculum at a minimum cadence of one (1) calendar year and update content to maintain alignment with applicable federal,
 state,
 and Manual requirements.
\end_layout

\begin_layout Itemize

\lang english
Shall maintain this policy and its implementing procedures consistent with CJIS Security Policy v6.0:
 Section AT-1 (Policy and Procedures).
\end_layout

\end_deeper
\begin_layout Itemize

\series bold
\lang english
Assistant IT Director
\series default
:
\end_layout

\begin_deeper
\begin_layout Itemize

\lang english
Shall develop and deliver the technical and role-based training content.
\end_layout

\begin_layout Itemize

\lang english
Shall disseminate emerging threat advisories and security alerts to affected personnel within one (1) business day of identifying a threat materially affecting County users,
 systems,
 or data.
\end_layout

\end_deeper
\begin_layout Itemize

\series bold
\lang english
Human Resources
\series default
:
\end_layout

\begin_deeper
\begin_layout Itemize

\lang english
Shall schedule and track completion of the general security awareness curriculum for all County personnel.
\end_layout

\begin_layout Itemize

\lang english
Shall collect training-completion documentation and transmit it to Information Operations for authoritative retention.
\end_layout

\begin_layout Itemize

\lang english
Shall verify completion of initial security awareness training prior to authorizing onboarding or credentialing of any individual.
\end_layout

\begin_layout Itemize

\lang english
Shall enforce administrative actions for personnel who fail to meet the annual refresher cadence required by this policy.
\end_layout

\end_deeper
\begin_layout Itemize

\series bold
\lang english
Department Heads
\series default
:
\end_layout

\begin_deeper
\begin_layout Itemize

\lang english
Shall ensure that one hundred percent (100%) of personnel and authorized non-employees under their operational authority complete initial and annual training within the cadence required by this policy.
\end_layout

\begin_layout Itemize

\lang english
Shall notify Information Operations and Human Resources of any subordinate who has not completed required training by the applicable deadline.
\end_layout

\end_deeper
\begin_layout Itemize

\series bold
\lang english
All County Personnel
\series default
:
\end_layout

\begin_deeper
\begin_layout Itemize

\lang english
Shall complete all assigned training modules and practical exercises by the deadlines established under this policy.
\end_layout

\begin_layout Itemize

\lang english
Shall apply training concepts to daily operations and report suspected security anomalies in accordance with 
\series bold
Policy 
\begin_inset CommandInset ref
LatexCommand ref
reference "pol:4.02"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset


\series default
 (Identification and Reporting Procedures).
\end_layout

\end_deeper
