\end_layout

\begin_layout Itemize

\lang english
Role-based training for privileged users,
 privacy-data handlers,
 and physical security personnel.
\end_layout

\begin_layout Itemize

\lang english
Practical security exercises,
 including spear-phishing simulations.
\end_layout

\begin_layout Itemize

\lang english
