\begin_layout Subsection*

\lang english
1.
 Purpose
\end_layout

\begin_layout Standard

\lang english
This policy establishes the mandatory security awareness and role-based training requirements for all personnel granted access to Elko County information technology resources.
\end_layout

\begin_layout Subsection*

\lang english
2.
 Scope
\end_layout

\begin_layout Standard

\lang english
This policy applies to all County personnel and authorized non-employees,
 including employees,
 elected officials,
 appointed officials,
 contractors,
 vendors,
 interns,
 volunteers,
 and service providers,
 who are granted logical access to County information technology resources,
 who process or handle County data,
 or who possess unescorted physical access to areas designated as physically secure locations.
\end_layout

