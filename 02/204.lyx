\end_layout

\begin_layout Itemize

\lang english
Least privilege and separation of duties enforcement.
\end_layout

\begin_layout Itemize

\lang english
Remote and wireless access authorization.
\end_layout

\begin_layout Itemize

\lang english
Session management,
 device lock,
 and unsuccessful-logon handling.
\end_layout

\begin_layout Itemize

\lang english
Periodic access recertification.
