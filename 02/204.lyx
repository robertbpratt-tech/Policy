\begin_layout Subsection*

\lang english
1.
 Purpose
\end_layout

\begin_layout Standard

\lang english
This policy establishes mandatory requirements for managing logical access to Elko County information systems,
 networks,
 and data.
\end_layout

\begin_layout Subsection*

\lang english
2.
 Scope
\end_layout

\begin_layout Standard

\lang english
This policy applies to all individuals with logical access to Elko County information systems,
 networks,
 or data,
 including employees,
 elected officials,
 appointed officials,
 interns,
 volunteers,
 contractors,
 and third-party vendors.
\end_layout

