\lang english
3.
 Roles and Responsibilities
\end_layout

\begin_layout Itemize

\series bold
\lang english
IT Director
\end_layout

\begin_deeper
\begin_layout Itemize

\lang english
Shall serve as the final Authentication Authority for enterprise standards.
 
\end_layout

\begin_layout Itemize

\lang english
Shall approve all County authentication architectures and enterprise MFA technology selections.
\end_layout

\end_deeper
\begin_layout Itemize

\series bold
\lang english
Human Resources (HR)
\end_layout

\begin_deeper
\begin_layout Itemize

\lang english
Shall serve as the Authoritative Source for workforce identity proofing and shall manage the lifecycle of physical County identity credentials.
\end_layout

\end_deeper
\begin_layout Itemize

\series bold
\lang english
Information Operations (Administrators)
\end_layout

\begin_deeper
\begin_layout Itemize

\lang english
Shall configure and manage the Identity and Access Management (IAM) infrastructure,
 bind authenticators to verified identities,
 and execute credential revocation within required timeframes.
\end_layout

\end_deeper
\begin_layout Itemize

\series bold
\lang english
System and Data Owners
\end_layout

\begin_deeper
\begin_layout Itemize

\lang english
Shall determine required authentication strength based on data classification and shall coordinate implementation with ECIO.
\end_layout

\end_deeper
\begin_layout Itemize

\series bold
\lang english
All Users
\end_layout

\begin_deeper
\begin_layout Itemize

\lang english
Shall protect County-issued authenticators from unauthorized use
\end_layout

\begin_layout Itemize

\lang english
Shall report suspected compromise,
 loss,
 or theft within the timelines defined in Section 6.3.
\end_layout

\end_deeper
