\begin_layout Subsection*

\lang english
1.
 Purpose
\end_layout

\begin_layout Standard

\lang english
This policy establishes mandatory System Development Life Cycle (SDLC) and secure software engineering requirements for Elko County information systems,
 including those processing,
 storing,
 or transmitting Criminal Justice Information (CJI).
\end_layout

\begin_layout Subsection*

\lang english
2.
 Scope
\end_layout

\begin_layout Standard

\lang english
