\begin_layout Subsubsection*

\lang english
6.7 High-Risk Individual Definition
\end_layout

\begin_layout Standard

\lang english
The following conditions qualify an individual as a High-Risk Individual for purposes of Section 6.5:
\end_layout

\begin_layout Itemize

\lang english
The individual has been involuntarily or hostilely terminated from County employment or service.
\end_layout

\begin_layout Itemize

\lang english
The individual has been identified by Human Resources,
 the IT Director,
 the County Manager,
 or the District Attorney's Office as posing a credible threat of misuse or retaliation.
\end_layout

\begin_layout Itemize

\lang english
The individual has received formal written notice of investigation from law enforcement,
 the District Attorney's Office,
 or a federal agency.
\end_layout

\begin_layout Itemize

\lang english
The individual has been identified by the IT Director (as LASO) or the CSO as a direct threat to CJI confidentiality or integrity.
\end_layout

