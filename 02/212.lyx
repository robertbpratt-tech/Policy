\begin_layout Subsubsection*

\lang english
6.10 Vendor Data Return
\end_layout

\begin_layout Standard

\lang english
At vendor contract termination or project completion initiated under 
\series bold
Policy 
\begin_inset CommandInset ref
LatexCommand ref
reference "pol:1.13"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset


\series default
 (Supply Chain Risk Management and Vendor Governance),
 the IT Director shall direct one of the following dispositions for County data held by the vendor.
\end_layout

\begin_layout Itemize

\series bold
\lang english
Certified Return
\series default
:
 The vendor shall return all County data to the Information Operations Department on County-approved media,
 accompanied by written certification that no copies have been retained.
\end_layout

\begin_layout Itemize

\series bold
\lang english
Secure Destruction
\series default
:
 The vendor shall destroy all County data using methods consistent with Section 6.4 and shall provide a written Certificate of Destruction identifying the data destroyed,
 the method used,
 the date of destruction,
 and the responsible individual.
\end_layout

\begin_layout Itemize

\series bold
\lang english
Verification
\series default
:
 The IT Director shall verify receipt of the returned media or the Certificate of Destruction and shall record the verification in the vendor contract file.
\end_layout

