\begin_layout Itemize

\lang english
Shall authorize each remote access connection type prior to deployment.
\end_layout

\begin_layout Itemize

\lang english
Shall authorize each wireless access type prior to deployment.
\end_layout

\begin_layout Itemize

\lang english
Shall approve the enterprise mobile device management (MDM) platform.
\end_layout

\begin_layout Itemize

\lang english
Shall designate compelling operational needs for privileged remote access.
\end_layout

\begin_layout Itemize

\lang english
