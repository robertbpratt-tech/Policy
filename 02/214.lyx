\begin_layout Subsection*

\lang english
1.
 Purpose
\end_layout

\begin_layout Standard

\lang english
This policy establishes mandatory security controls for mobile devices and remote access technologies connecting to Elko County information systems,
 including those processing,
 storing,
 or transmitting Criminal Justice Information (CJI).
\end_layout

\begin_layout Subsection*

\lang english
2.
 Scope
\end_layout

\begin_layout Standard

\lang english
This policy applies to all Elko County information systems,
 mobile devices,
 wireless infrastructure,
 and remote access connections,
 and to all County Personnel,
 contractors,
 and third-party vendors interacting with these resources.
\end_layout

