LatexCommand ref
reference "pol:5.01"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset


\series default
.
\end_layout

\end_deeper
\begin_layout Itemize

\series bold
\lang english
Assistant IT Director:
\end_layout

\begin_deeper
\begin_layout Itemize

\lang english
Shall perform a pre-departure inspection on each CJI-authorized device approved for international travel.
\end_layout

\begin_layout Itemize

\lang english
Shall perform a post-return inspection on each CJI-authorized device upon its return to County custody from international travel.
\end_layout

\begin_layout Itemize

\lang english
Shall receive immediate reports of lost,
 stolen,
 or suspected-compromise mobile devices from County Personnel.
\end_layout

\end_deeper
\begin_layout Itemize

\series bold
\lang english
Systems Administrator:
\end_layout

\begin_deeper
\begin_layout Itemize

\lang english
Shall configure and maintain the enterprise mobile device management (MDM) platform per the requirements in Section 6.3.
\end_layout

\begin_layout Itemize

\lang english
Shall apply security patches to mobile operating systems per 
\series bold
Policy 
\begin_inset CommandInset ref
LatexCommand ref
reference "pol:2.09"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset


\series default
.
\end_layout

\begin_layout Itemize

\lang english
Shall initiate remote lock and remote wipe procedures via the MDM platform upon notification of mobile device loss,
 theft,
 or compromise.
\end_layout

\begin_layout Itemize

\lang english
Shall configure cryptographic key extraction protections and remote-wipe-on-failure controls on CJI-authorized mobile devices.
\end_layout

\end_deeper
\begin_layout Itemize

\series bold
\lang english
Network Administrator:
\end_layout

\begin_deeper
\begin_layout Itemize

\lang english
Shall configure and maintain the County's Virtual Private Network (VPN) and remote access gateway infrastructure.
\end_layout

\begin_layout Itemize

\lang english
Shall route remote access traffic through authorized and managed network access control points.
\end_layout

\begin_layout Itemize

\lang english
Shall perform validation testing for rogue wireless access points no less frequently than quarterly.
\end_layout

\begin_layout Itemize

\lang english
Shall maintain the inventory of all County wireless access points.
\end_layout

\begin_layout Itemize

\lang english
Shall configure wireless infrastructure per the requirements in Section 6.2.
\end_layout

\begin_layout Itemize

\lang english
Shall change administrative credentials on wireless access points consistent with the configuration baselines defined in 
\series bold
Policy 
\begin_inset CommandInset ref
LatexCommand ref
reference "pol:2.10"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset


\series default
.
\end_layout

\end_deeper
\begin_layout Itemize

\series bold
\lang english
All County Personnel:
\end_layout

\begin_deeper
\begin_layout Itemize

\lang english
Shall physically protect County mobile devices in their custody.
\end_layout

\begin_layout Itemize

\lang english
Shall report the loss,
 theft,
 or suspected compromise of any County mobile device to the Assistant IT Director immediately upon discovery and no later than two (2) hours after discovery.
\end_layout

\begin_layout Itemize

\lang english
Shall report the loss,
 theft,
 or suspected compromise of any CJI-authorized mobile device to the IT Director (as LASO) immediately and no later than one (1) hour after discovery.
\end_layout

\begin_layout Itemize

\lang english
Shall initiate session locks before leaving County devices unattended.
\end_layout

\begin_layout Itemize

\lang english
Shall not connect personally owned devices to the County's internal trusted network or use personally owned devices to access CJI.
\end_layout

\begin_layout Itemize

\lang english
Shall not transport CJI-authorized devices outside the United States without prior written authorization from the IT Director (as LASO).
\end_layout

\end_deeper
