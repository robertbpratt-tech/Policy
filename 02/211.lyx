\lang english
6.9 Decommissioned-System Log Handling
\end_layout

\begin_layout Standard

\lang english
When a County information system is scheduled for decommissioning under 
\series bold
Policy 
\begin_inset CommandInset ref
LatexCommand ref
reference "pol:1.12"
