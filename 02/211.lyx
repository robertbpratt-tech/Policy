\begin_layout Subsection*

\lang english
1.
 Purpose
\end_layout

\begin_layout Standard

\lang english
This policy establishes the requirements for the generation,
 protection,
 review,
 and retention of security audit logs across all Elko County information systems.
\end_layout

\begin_layout Subsection*

\lang english
2.
 Scope
\end_layout

\begin_layout Standard

\lang english
This policy applies to all County information systems,
 network infrastructure,
 endpoints,
 and cloud services that process,
 store,
 or transmit County data,
 and to all Information Operations personnel and County Personnel who generate,
 configure,
 review,
 or interact with audit records produced by those systems.
\end_layout

