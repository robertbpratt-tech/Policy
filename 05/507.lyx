\begin_layout Subsection*

\lang english
1.
 Purpose
\end_layout

\begin_layout Standard

\lang english
This policy establishes the annual policy review process,
 maturity scoring methodology,
 and executive reporting requirements that the Information Operations Department uses to evaluate the implementation effectiveness and operational maturity of the ECIO Policy Manual.
\end_layout

