\begin_layout Subsection*

\lang english
1.
 Purpose
\end_layout

\begin_layout Standard

\lang english
This policy governs the development,
 approval,
 tracking,
 and closure of Corrective Action Plans and establishes the compliance monitoring function that verifies the Department's ongoing adherence to its statutory and regulatory notification obligations.
\end_layout

