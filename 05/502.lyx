caps "false"
noprefix "false"
nolink "false"

\end_inset


\series default
.
\end_layout

\begin_layout Subsubsection*

\lang english
6.6 Audit Record Retention
\end_layout

\begin_layout Standard

\lang english
The Assistant IT Director shall retain audit records,
 self-assessment documentation,
 control test results,
 evidence artifacts,
 and audit summary reports in the System of Engagement in accordance with 
\series bold
Policy 
\begin_inset CommandInset ref
LatexCommand ref
reference "pol:1.11"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset


\series default
 and the applicable Nevada Local Government Records Retention Schedule.
 Where multiple retention requirements apply,
 the longest applicable period shall govern.
 Audit records shall be retained for a minimum of three (3) years from the date of the assessment where no longer retention period is specified by an applicable schedule.
\end_layout

