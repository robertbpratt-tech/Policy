\end_layout

\begin_layout Itemize

\lang english
Account lockout (disabling an account pending investigation or remediation).
\end_layout

\begin_layout Itemize

\lang english
Increased audit frequency (enhanced monitoring of the affected account,
 system,
 or network segment).
\end_layout

\begin_layout Itemize

\lang english
